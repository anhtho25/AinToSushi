{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "chatbot": {
      "config": {
        ".read": "true",
        ".write": "auth != null"
      },
      "conversations": {
        ".read": "auth != null",
        ".write": "true"
      }
    },
    "menu": {
      "menuOnline": {
        ".read": "true",
        ".write": "auth != null",
        "$productId": {
          "reviews": {
            ".read": "true",
            ".write": "true"
          }
        }
      }
    },
    "orders": {
      "$orderId": {
        ".read": "auth != null && data.child('userId').val() == auth.uid",
        ".write": "auth != null && newData.child('userId').val() == auth.uid"
      }
    }
  }
}
